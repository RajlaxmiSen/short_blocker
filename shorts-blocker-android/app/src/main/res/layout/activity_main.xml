<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Shorts Blocker"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Take control of your Shorts usage"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: Shorts BLOCKED"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_red"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_timer_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:visibility="invisible" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sessions Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daily Usage"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_sessions_remaining"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sessions today: 0 / 5"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progress_sessions"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="5"
                    android:progress="0"
                    android:progressTint="@color/accent_red"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Each session = 10 minutes. Max 5 per day. Resets at midnight."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Warnings -->
        <TextView
            android:id="@+id/tv_warnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/warning_bg"
            android:textColor="@color/warning_text"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btn_enter_temp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Enter Temporary Password"
            android:textSize="16sp"
            android:backgroundTint="@color/accent_blue"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_enter_permanent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Enter Permanent Password"
            android:textSize="16sp"
            android:backgroundTint="@color/accent_dark"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Settings"
            android:textSize="14sp"
            android:backgroundTint="@color/card_bg"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
